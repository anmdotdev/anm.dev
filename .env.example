# Turso database (https://turso.tech)
# Leave unset for local development (uses file:data/blog.db)
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Enable future-dated blog posts in production for local/staging preview.
ENABLE_SCHEDULED_CONTENT_PREVIEW=false

# Public site URL
SITE_URL=https://anm.dev

# Resend newsletter delivery
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=blog@updates.anm.dev
RESEND_FROM_NAME=Anmol Mahatpurkar via anmdotdev
RESEND_REPLY_TO_EMAIL=hey@anm.dev
RESEND_NEWSLETTER_SEGMENT_ID=segment_xxxxxxxxx
RESEND_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxx

# Protected scheduler and admin endpoints
CRON_SECRET=replace-with-a-random-secret
NEWSLETTER_ADMIN_SECRET=replace-with-a-different-random-secret
